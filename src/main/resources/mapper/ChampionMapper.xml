<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.LOLCAA.mapper.ChampionMapper">

    <select id="findById" resultType="com.LOLCAA.entity.Champion">
        SELECT * FROM champion WHERE id = #{id}
    </select>

    <select id="findByIds" resultType="com.LOLCAA.entity.Champion">
        SELECT * FROM champion
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="findAll" resultType="com.LOLCAA.entity.Champion">
        SELECT * FROM champion
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO champion(name, role, tier, pick_rate, win_rate)
        VALUES (#{name}, #{role}, #{tier}, #{pickRate}, #{winRate})
    </insert>

    <update id="update">
        UPDATE champion
        SET name=#{name},
            role=#{role},
            tier=#{tier},
            pick_rate=#{pickRate},
            win_rate=#{winRate}
        WHERE id=#{id}
    </update>

    <delete id="deleteById">
        DELETE FROM champion WHERE id=#{id}
    </delete>

</mapper>